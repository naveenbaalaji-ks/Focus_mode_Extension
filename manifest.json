{
  "manifest_version": 3,
  "name": "Focus Mode Pro",
  "version": "2.1",
  "description": "Interactive focus timer with an evolving pet, stats, full dashboard, and audio.",
  "permissions": ["storage", "notifications", "offscreen", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}